    # Agent modifies .env during task
    (worktree / ".env").write_text("KEY=modified_by_agent")

    # Task T01 end
    await lifecycle.on_task_end("run-1", "T01", worktree)

    # Task T02 should see modified state
    await lifecycle.on_task_start("run-1", "T02", worktree)
    assert (worktree / ".env").read_text() == "KEY=modified_by_agent"

    # Run end (success)
    await lifecycle.on_run_end("run-1", "proj-1", worktree, success=True)

    # Canonical should be updated
    canonical = store._canonical_dir("proj-1")
    assert (canonical / ".env").read_text() == "KEY=modified_by_agent"
