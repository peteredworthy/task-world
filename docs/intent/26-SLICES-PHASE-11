@app.command()
def copy_back(
    run_id: str,
    target: str | None = typer.Option(None, help="Target directory. Defaults to original source dir."),
    file: list[str] | None = typer.Option(None, help="Specific files to copy. Repeatable."),
    snapshot: str = typer.Option("run_end", help="Snapshot to copy from."),
    interactive: bool = typer.Option(False, help="Interactively select snapshot and files."),
):
    """Copy environment files from a completed run to a target directory."""
    # Get default target if not specified
    if target is None:
        default = api_client.get(f"/runs/{run_id}/env-files/default-target")
        target = default.get("default_target")
        if target is None:
            typer.echo("No default target directory. Please specify --target.", err=True)
            raise typer.Exit(1)
        typer.echo(f"Using default target: {target}")

    if interactive:
        snapshots = api_client.get(f"/runs/{run_id}/env-files/snapshots")
        # Present snapshot list, let user pick
        snapshot = _interactive_snapshot_select(snapshots["snapshots"])
        # Present file list from chosen snapshot, let user pick
        files_in_snap = next(s["files"] for s in snapshots["snapshots"] if s["snapshot_id"] == snapshot)
        file = _interactive_file_select(files_in_snap)

    result = api_client.post(f"/runs/{run_id}/env-files/copy-back", json={
        "target_dir": target,
        "snapshot_id": snapshot,
        "files": file,
    })

    typer.echo(f"Copied {len(result['files_copied'])} files to {target}:")
    for f in result["files_copied"]:
        typer.echo(f"  ✓ {f}")
