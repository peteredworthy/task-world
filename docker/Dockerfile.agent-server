FROM python:3.12-slim

# Install system dependencies - NOTE: tmux intentionally excluded to avoid race condition bug
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    locales \
    && rm -rf /var/lib/apt/lists/* \
    && sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen \
    && locale-gen

# Set locale environment variables
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US:en
ENV LC_ALL=en_US.UTF-8

# Install openhands-ai
RUN pip install --no-cache-dir "openhands-ai>=1.3.0"

# Create openhands user and workspace
RUN useradd -m -s /bin/bash openhands && \
    mkdir -p /workspace && \
    chown openhands:openhands /workspace

USER openhands
WORKDIR /home/openhands

EXPOSE 8000

ENTRYPOINT ["python", "-m", "openhands.agent_server"]
CMD ["--host", "0.0.0.0", "--port", "8000"]
