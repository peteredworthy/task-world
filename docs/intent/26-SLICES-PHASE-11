async def recover_state():
    # ... existing recovery ...

    # Clean up orphaned env file snapshots
    active_ids = {run.id for run in await get_all_runs()}
    cleanup = EnvFileCleanup(env_file_store)
    removed = cleanup.cleanup_deleted_runs(active_ids)
    if removed:
        logger.info(f"Cleaned up {removed} orphaned env file snapshot(s)")

    # Recover env file state from event history
    # If a run was active when the process crashed, the last env_file_snapshot
    # event tells us the most recent snapshot. The worktree may have had
    # modifications since then that weren't captured — this is acceptable
    # because the snapshot captures happen at well-defined lifecycle boundaries.
    for run in await get_active_runs():
        try:
            manifest = env_file_store.load_manifest(run.id)
            logger.info(
                f"Run {run.id}: env file manifest recovered, "
                f"{len(manifest.snapshots)} snapshots available"
            )
        except SnapshotNotFoundError:
            # Run may not have env files configured — this is fine
            pass
