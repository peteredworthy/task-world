            <option key={s.snapshot_id} value={s.snapshot_id}>
              {s.snapshot_id} ({s.type}) — {formatTime(s.timestamp)}
            </option>
          ))}
        </select>
      </div>

      {/* File selector */}
      {currentSnapshot && (
        <div className="mb-3">
          <label className="text-sm text-gray-600">Files (deselect to copy all)</label>
          {currentSnapshot.files.map(f => (
            <label key={f} className="flex items-center gap-2 mt-1">
              <input
                type="checkbox"
                checked={selectedFiles.length === 0 || selectedFiles.includes(f)}
                onChange={e => {
                  if (selectedFiles.length === 0) {
                    // Switching from "all" to selective
                    setSelectedFiles(currentSnapshot.files.filter(x => x !== f));
                  } else if (e.target.checked) {
                    setSelectedFiles([...selectedFiles, f]);
                  } else {
                    setSelectedFiles(selectedFiles.filter(x => x !== f));
                  }
                }}
              />
              <span className="text-sm font-mono">{f}</span>
            </label>
          ))}
        </div>
      )}

      <button
        onClick={handleCopyBack}
        disabled={!targetDir || mutation.isLoading}
        className="btn-primary"
      >
        {mutation.isLoading ? 'Copying...' : 'Copy Files'}
      </button>

      {result && (
        <div className="mt-3 p-3 bg-green-50 border border-green-200 rounded">
          <p className="text-sm text-green-800">
            Copied {result.files_copied.length} files to {result.target_dir}
          </p>
        </div>
      )}
    </div>
  );
}
