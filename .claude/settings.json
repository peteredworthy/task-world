{
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Glob(./**)",
      "Grep(./**)"
    ],
    "deny": []
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "./",
        "//tmp",
        "~/.cache/pre-commit"
      ]
    },
    "network": {
      "allowedDomains": [
        "localhost",
        "127.0.0.1"
      ]
    }
  }
}
